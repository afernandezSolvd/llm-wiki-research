# Database
DATABASE_URL=postgresql+asyncpg://llmwiki:llmwiki@localhost:5432/llmwiki

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Anthropic (LLM)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# Voyage (embeddings — separate key from Anthropic)
VOYAGE_API_KEY=pa-...
ANTHROPIC_EMBEDDING_MODEL=voyage-3-large

# Storage (use "local" for dev, "s3" for prod)
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./data/sources
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=llm-wiki-sources
# AWS_REGION=us-east-1

# Wiki git repos root
WIKI_REPOS_ROOT=./wiki_repos

# Workers
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Rate limiting (requests per minute per user)
RATE_LIMIT_DEFAULT=120
RATE_LIMIT_INGEST=10
RATE_LIMIT_QUERY=60
RATE_LIMIT_LINT=5

# Semantic drift alert threshold (cosine distance)
DRIFT_ALERT_THRESHOLD=0.35

# KG community rebuild debounce (minutes)
KG_COMMUNITY_REBUILD_DEBOUNCE_MINUTES=10

# Hot pages cache (top-N pages to include in prompt cache block)
HOT_PAGES_CACHE_TOP_N=10
HOT_PAGES_CACHE_TTL_SECONDS=900

# Hallucination gate (set to false to disable for dev speed)
HALLUCINATION_GATE_ENABLED=true

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
